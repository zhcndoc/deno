vm/" class="sub-nav-link blocklink">vm</a></li><li><a href="../../.././wasi/" class="sub-nav-link blocklink">wasi</a></li><li><a href="../../.././worker_threads/" class="sub-nav-link blocklink">worker_threads</a></li><li><a href="../../.././zlib/" class="sub-nav-link blocklink">zlib</a></li><li><a href="../../.././all_symbols" class="sub-nav-link blocklink">View all 2550 symbols</a></li></ul></nav></div><div id="content" class="content"><div class="px-4 sm:px-5 md:px-6 w-full mx-auto 2xl:px-0 max-w-[40rem]"><article class="mx-auto"><div data-color-mode="auto" data-light-theme="light" data-dark-theme="dark" class="markdown-body mt-4 rounded-lg"><div class="ddoc markdown-body"><link rel="stylesheet" href="/reference_styles.css"/><ul class="breadcrumbs refcrumbs"><li><a href="../../../" class="contextLink">Node</a></li><span class="text-[#0F172A]"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M5.76748 11.8159C5.5378 11.577 5.54525 11.1972 5.78411 10.9675L8.93431 8L5.78411 5.0325C5.54525 4.80282 5.5378 4.423 5.76748 4.18413C5.99715 3.94527 6.37698 3.93782 6.61584 4.1675L10.2158 7.5675C10.3335 7.68062 10.4 7.83679 10.4 8C10.4 8.16321 10.3335 8.31938 10.2158 8.4325L6.61584 11.8325C6.37698 12.0622 5.99715 12.0547 5.76748 11.8159Z" fill="currentColor"></path></svg></span><li><a href="../../.././inspector/promises/" class="contextLink">inspector/promises</a></li><span class="text-[#0F172A]"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M5.76748 11.8159C5.5378 11.577 5.54525 11.1972 5.78411 10.9675L8.93431 8L5.78411 5.0325C5.54525 4.80282 5.5378 4.423 5.76748 4.18413C5.99715 3.94527 6.37698 3.93782 6.61584 4.1675L10.2158 7.5675C10.3335 7.68062 10.4 7.83679 10.4 8C10.4 8.16321 10.3335 8.31938 10.2158 8.4325L6.61584 11.8325C6.37698 12.0622 5.99715 12.0547 5.76748 11.8159Z" fill="currentColor"></path></svg></span><span><li><a href="../../.././inspector/promises/~/Session" class="contextLink">Session</a></li><span>.</span><li><a href="../../.././inspector/promises/~/Session.prototype" class="contextLink">prototype</a></li><span>.</span><li>post</li></span></ul><div id="content"><main class="symbolGroup" id="symbol_Session.prototype.post"><article><h1 class="ref-h1"><span class="text-Method">method</span> <span class="font-bold">Session.prototype.post</span></h1><div class="space-x-2 !mt-2"><div class="text-unstable border border-unstable/50 bg-unstable/5 inline-flex items-center gap-0.5 flex-none rounded-md leading-none font-bold py-2 px-3">unstable</div></div><div><div class="mt-3"><h2>Overload 1</h2><div class="scroll-mt-16" id="function_Session_prototype_post_0"><code class="anchorable break-words inline-code-block"><a href="#function_Session_prototype_post_0" class="anchor-link" aria-label="Anchor" tabindex="-1">#</a><span class="font-bold">Session.prototype.post</span><span class="font-medium">(<div class="ml-4"><div><span>method<span>: <span>string</span></span></span>,</div><div><span>params?<span>: <span>object</span></span></span>,</div></div>)<span>: <span>Promise</span>&lt;<span>void</span>&gt;</span></span></code><div class="space-y-7" id><div><div data-color-mode="dark" data-light-theme="light" data-dark-theme="dark" class="markdown-body"><p>Posts a message to the inspector back-end.</p>
<div class="relative"><pre><code class="highlight notranslate language-js"><span class="token keyword">import</span> <span class="token punctuation">{</span> Session <span class="token punctuation">}</span> <span class="token keyword">from</span> <span class="token string">'node:inspector/promises'</span><span class="token punctuation">;</span>
<span class="token keyword">try</span> <span class="token punctuation">{</span>
  <span class="token keyword">const</span> session <span class="token operator">=</span> <span class="token keyword">new</span> <span class="token class-name">Session</span><span class="token punctuation">(</span><span class="token punctuation">)</span><span class="token punctuation">;</span>
  session<span class="token punctuation">.</span><span class="token function">connect</span><span class="token punctuation">(</span><span class="token punctuation">)</span><span class="token punctuation">;</span>
  <span class="token keyword">const</span> result <span class="token operator">=</span> <span class="token keyword">await</span> session<span class="token punctuation">.</span><span class="token function">post</span><span class="token punctuation">(</span><span class="token string">'Runtime.evaluate'</span><span class="token punctuation">,</span> <span class="token punctuation">{</span> <span class="token literal-property property">expression</span><span class="token operator">:</span> <span class="token string">'2 + 2'</span> <span class="token punctuation">}</span><span class="token punctuation">)</span><span class="token punctuation">;</span>
  console<span class="token punctuation">.</span><span class="token function">log</span><span class="token punctuation">(</span>result<span class="token punctuation">)</span><span class="token punctuation">;</span>
<span class="token punctuation">}</span> <span class="token keyword">catch</span> <span class="token punctuation">(</span>error<span class="token punctuation">)</span> <span class="token punctuation">{</span>
  console<span class="token punctuation">.</span><span class="token function">error</span><span class="token punctuation">(</span>error<span class="token punctuation">)</span><span class="token punctuation">;</span>
<span class="token punctuation">}</span>
<span class="token comment">// Output: { result: { type: 'number', value: 4, description: '4' } }</span>
</code></pre>

      <button id="copy-button-3" class="copyButton" data-copy="import { Session } from &apos;node:inspector/promises&apos;;
try {
  const session = new Session();
  session.connect();
  const result = await session.post(&apos;Runtime.evaluate&apos;, { expression: &apos;2 + 2&apos; });
  console.log(result);
} catch (error) {
  console.error(error);
}
// Output: { result: { type: &apos;number&apos;, value: 4, description: &apos;4&apos; } }
