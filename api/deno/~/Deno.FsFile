header-nav-link blocklink " data-active="true" aria-current="location">API 参考</a><a href="/examples/" class="header-nav-link blocklink ">示例</a><a href="/services/" class="header-nav-link blocklink services">服务</a></nav><a href="https://www.zhcndoc.com" class="external blocklink" target="_blank">简中文档</a><form action="https://www.google.com/search" method="get" class="search" target="_blank"><input type="search" name="q" id="search-str" placeholder="Search" class="search-input"/><input type="hidden" name="q" id="q" value="site:deno.com"/></form><button type="button" aria-label="toggle theme" class="theme-toggle" id="theme-toggle">Toggle Theme</button></header><nav class="refheader"><ul class="flex"><li><a class="blocklink refheader-link" data-active="true" href="/api/deno">Deno APIs</a></li><li><a class="blocklink refheader-link" data-active="false" href="/api/web">Web APIs</a></li><li><a class="blocklink refheader-link" data-active="false" href="/api/node">Node APIs</a></li></ul></nav><div class="layout"><label for="hamburger" class="hamburger-label"><span class="hamburger-bar hamburger-bar--top"></span><span class="hamburger-bar hamburger-bar--middle"></span><span class="hamburger-bar hamburger-bar--bottom"></span><span class="sr-only">Toggle navigation menu</span></label><input type="checkbox" id="hamburger" class="hamburger-checkbox"/><div class="nav" data-section="api" id="nav"><nav aria-labelledby="primary-navigation"><ul class="main-nav"><li><a href="/runtime/" class="main-nav-link">手册</a></li><li><a href="/api/deno/" class="main-nav-link" data-active="true">API 参考</a></li><li><a href="/examples/" class="main-nav-link">示例</a></li><li><a href="/services/" class="main-nav-link">服务</a></li></ul></nav><nav aria-labelledby="section-navigation"><ul class="sub-nav"><li><a href=".././cloud" class="sub-nav-link blocklink">Cloud</a></li><li><a href=".././errors" class="sub-nav-link blocklink">Errors</a></li><li><a href=".././ffi" class="sub-nav-link blocklink">FFI</a></li><li><a href=".././fetch" class="sub-nav-link blocklink">Fetch</a></li><li><a href=".././file-system" class="sub-nav-link blocklink">File System</a></li><li><a href=".././gpu" class="sub-nav-link blocklink">GPU</a></li><li><a href=".././http-server" class="sub-nav-link blocklink">HTTP Server</a></li><li><a href=".././io" class="sub-nav-link blocklink">I/O</a></li><li><a href=".././jupyter" class="sub-nav-link blocklink">Jupyter</a></li><li><a href=".././linter" class="sub-nav-link blocklink">Linter</a></li><li><a href=".././network" class="sub-nav-link blocklink">Network</a></li><li><a href=".././permissions" class="sub-nav-link blocklink">Permissions</a></li><li><a href=".././runtime" class="sub-nav-link blocklink">Runtime</a></li><li><a href=".././subprocess" class="sub-nav-link blocklink">Subprocess</a></li><li><a href=".././telemetry" class="sub-nav-link blocklink">Telemetry</a></li><li><a href=".././testing" class="sub-nav-link blocklink">Testing</a></li><li><a href=".././websockets" class="sub-nav-link blocklink">WebSockets</a></li><li></li><li><a href=".././all_symbols" class="sub-nav-link blocklink">View all 502 symbols</a></li></ul></nav></div><div id="content" class="content"><div class="px-4 sm:px-5 md:px-6 w-full mx-auto 2xl:px-0 max-w-[40rem]"><article class="mx-auto"><div data-color-mode="auto" data-light-theme="light" data-dark-theme="dark" class="markdown-body mt-4 rounded-lg"><div class="ddoc markdown-body"><link rel="stylesheet" href="/reference_styles.css"/><ul class="breadcrumbs refcrumbs"><li><a href="../" class="contextLink">Deno</a></li><span class="text-[#0F172A]"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M5.76748 11.8159C5.5378 11.577 5.54525 11.1972 5.78411 10.9675L8.93431 8L5.78411 5.0325C5.54525 4.80282 5.5378 4.423 5.76748 4.18413C5.99715 3.94527 6.37698 3.93782 6.61584 4.1675L10.2158 7.5675C10.3335 7.68062 10.4 7.83679 10.4 8C10.4 8.16321 10.3335 8.31938 10.2158 8.4325L6.61584 11.8325C6.37698 12.0622 5.99715 12.0547 5.76748 11.8159Z" fill="currentColor"></path></svg></span><span><li><a href="../././~/Deno" class="contextLink">Deno</a></li><span>.</span><li>FsFile</li></span></ul><div id="content"><main class="symbolGroup" id="symbol_Deno.FsFile"><article><h1 class="ref-h1"><span class="text-Class">class</span> <span class="font-bold">Deno.FsFile</span></h1><div class="symbolSubtitle"><div><span class="type">implements</span> <span><span>Disposable</span></span></div></div><div><div class="space-y-7" id><div><div data-color-mode="dark" data-light-theme="light" data-dark-theme="dark" class="markdown-body"><p>The Deno abstraction for reading and writing files.</p>
<p>This is the most straight forward way of handling files within Deno and is
recommended over using the discrete functions within the <code>Deno</code> namespace.</p>
<div class="relative"><pre><code class="highlight notranslate language-ts">using file <span class="token operator">=</span> <span class="token keyword">await</span> Deno<span class="token punctuation">.</span><span class="token function">open</span><span class="token punctuation">(</span><span class="token string">"/foo/bar.txt"</span><span class="token punctuation">,</span> <span class="token punctuation">{</span> read<span class="token operator">:</span> <span class="token boolean">true</span> <span class="token punctuation">}</span><span class="token punctuation">)</span><span class="token punctuation">;</span>
<span class="token keyword">const</span> fileInfo <span class="token operator">=</span> <span class="token keyword">await</span> file<span class="token punctuation">.</span><span class="token function">stat</span><span class="token punctuation">(</span><span class="token punctuation">)</span><span class="token punctuation">;</span>
<span class="token keyword">if</span> <span class="token punctuation">(</span>fileInfo<span class="token punctuation">.</span>isFile<span class="token punctuation">)</span> <span class="token punctuation">{</span>
  <span class="token keyword">const</span> buf <span class="token operator">=</span> <span class="token keyword">new</span> <span class="token class-name">Uint8Array</span><span class="token punctuation">(</span><span class="token number">100</span><span class="token punctuation">)</span><span class="token punctuation">;</span>
  <span class="token keyword">const</span> numberOfBytesRead <span class="token operator">=</span> <span class="token keyword">await</span> file<span class="token punctuation">.</span><span class="token function">read</span><span class="token punctuation">(</span>buf<span class="token punctuation">)</span><span class="token punctuation">;</span> <span class="token comment">// 11 bytes</span>
  <span class="token keyword">const</span> text <span class="token operator">=</span> <span class="token keyword">new</span> <span class="token class-name">TextDecoder</span><span class="token punctuation">(</span><span class="token punctuation">)</span><span class="token punctuation">.</span><span class="token function">decode</span><span class="token punctuation">(</span>buf<span class="token punctuation">)</span><span class="token punctuation">;</span>  <span class="token comment">// "hello world"</span>
<span class="token punctuation">}</span>
</code></pre>

      <button id="copy-button-6" class="copyButton" data-copy="using file = await Deno.open(&quot;/foo/bar.txt&quot;, { read: true });
const fileInfo = await file.stat();
if (fileInfo.isFile) {
  const buf = new Uint8Array(100);
  const numberOfBytesRead = await file.read(buf); // 11 bytes
  const text = new TextDecoder().decode(buf);  // &quot;hello world&quot;
}
